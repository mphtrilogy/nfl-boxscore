{
  "rewrites": [
    {
      "source": "/api/espn/athletes",
      "destination": "https://site.api.espn.com/apis/common/v3/sports/football/nfl/athletes"
    },
    {
      "source": "/api/espn/teams/:team/schedule",
      "destination": "https://site.api.espn.com/apis/site/v2/sports/football/nfl/teams/:team/schedule"
    },
    {
      "source": "/api/espn/:path*",
      "destination": "https://site.api.espn.com/apis/site/v2/sports/football/nfl/:path*"
    },
    {
      "source": "/api/espn-core/:path*",
      "destination": "https://sports.core.api.espn.com/v2/sports/football/leagues/nfl/:path*"
    },
    {
      "source": "/api/rss/pft",
      "destination": "https://profootballtalk.nbcsports.com/feed/"
    },
    {
      "source": "/api/rss/cbs",
      "destination": "https://www.cbssports.com/rss/headlines/nfl/"
    },
    {
      "source": "/api/rss/si",
      "destination": "https://www.si.com/rss/si_nfl.rss"
    },
    {
      "source": "/api/rss/ringer",
      "destination": "https://www.theringer.com/rss/nfl.xml"
    },
    {
      "source": "/api/rss/rotoworld",
      "destination": "https://www.rotowire.com/football/rss-news.php"
    },
    {
      "source": "/api/rss/fantasypros",
      "destination": "https://www.fantasypros.com/nfl/news/feed.xml"
    },
    {
      "source": "/api/rss/overthecap",
      "destination": "https://overthecap.com/feed/"
    },
    {
      "source": "/api/rss/theringer",
      "destination": "https://www.theringer.com/rss/nfl.xml"
    }
  ],
  "headers": [
    {
      "source": "/api/rss/(.*)",
      "headers": [
        { "key": "User-Agent", "value": "Mozilla/5.0 (compatible; RSS Reader)" },
        { "key": "Accept", "value": "application/rss+xml, application/xml, text/xml" }
      ]
    }
  ]
}
